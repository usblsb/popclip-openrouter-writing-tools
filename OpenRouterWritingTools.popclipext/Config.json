{
  "name": "OpenRouter Writing Tools",
  "identifier": "com.jl.openrouter.writingtools",
  "description": "7 AI writing actions powered by OpenRouter (OpenAI + Gemini): correct, translate, summarize, improve email, improve content, format HTML, format Markdown.",
  "icon": "symbol:wand.and.stars",
  "popclipVersion": 4069,
  "entitlements": ["network"],

  "options": [
    {
      "identifier": "apikey",
      "label": "OpenRouter API Key",
      "type": "string",
      "defaultValue": "",
      "description": "Get yours at https://openrouter.ai/keys (starts with sk-or-v1-...). Note: stored as plain string for now, will move to secret/Keychain in a later version."
    },
    {
      "identifier": "idioma_respuesta",
      "label": "Response language (most tasks)",
      "type": "string",
      "defaultValue": "auto",
      "description": "Language used for tasks #1, #3, #4, #5, #6, #7. Use 'auto' to keep the input language. Or write 'spanish', 'english', 'german'..."
    },
    {
      "identifier": "idioma_traducir",
      "label": "Target language (Translate task only)",
      "type": "string",
      "defaultValue": "spanish",
      "description": "Destination language for the Translate task. Examples: spanish, english, german, french, italian, portuguese, japanese."
    }
  ],

  "actions": [
    {
      "title": "Correct",
      "icon": "symbol:checkmark.seal.fill",
      "interpreter": "bash",
      "shell script": "python3 jl_writingtools.py corregir",
      "after": "paste-result",
      "requirements": ["text"]
    },
    {
      "title": "Translate",
      "icon": "symbol:globe",
      "interpreter": "bash",
      "shell script": "python3 jl_writingtools.py traducir",
      "after": "paste-result",
      "requirements": ["text"]
    },
    {
      "title": "Summarize",
      "icon": "symbol:text.alignleft",
      "interpreter": "bash",
      "shell script": "python3 jl_writingtools.py resumir",
      "after": "paste-result",
      "requirements": ["text"]
    },
    {
      "title": "Improve email/message",
      "icon": "symbol:envelope.fill",
      "interpreter": "bash",
      "shell script": "python3 jl_writingtools.py email",
      "after": "paste-result",
      "requirements": ["text"]
    },
    {
      "title": "Improve content",
      "icon": "symbol:doc.text.fill",
      "interpreter": "bash",
      "shell script": "python3 jl_writingtools.py contenido",
      "after": "paste-result",
      "requirements": ["text"]
    },
    {
      "title": "Format HTML",
      "icon": "symbol:chevron.left.forwardslash.chevron.right",
      "interpreter": "bash",
      "shell script": "python3 jl_writingtools.py html",
      "after": "paste-result",
      "requirements": ["text"]
    },
    {
      "title": "Format Markdown",
      "icon": "symbol:doc.richtext.fill",
      "interpreter": "bash",
      "shell script": "python3 jl_writingtools.py md",
      "after": "paste-result",
      "requirements": ["text"]
    }
  ]
}
